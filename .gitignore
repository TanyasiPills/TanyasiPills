# This .gitignore file should be placed at the root of your Unity project directory
# (the folder containing Assets/, Packages/, ProjectSettings/)

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
UserSettings/

# MemoryCaptures can get excessive in size
MemoryCaptures/

# Asset meta data should only be ignored when the corresponding asset is also ignored
# (do NOT ignore *.meta globally)

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
.idea/
.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files (only ignore if you know what you're doing)
# *.meta

# Builds
*.apk
*.aab
*.unitypackage
*.app
*.exe
*.ipa

# Crash reports
sysinfo.txt

# OS generated files
.DS_Store
Thumbs.db

# Addressables
ServerData/

# Rider
.idea/

# Visual Studio Code
.vscode/

# Gradle
.gradle/